# Postgres connection string used by the indexer and sqlx tooling.
CELLORA_DATABASE_URL=postgres://cellora:cellora@localhost:5432/cellora

# CKB JSON-RPC endpoint. In local dev this points at the dev node defined
# in docker-compose.yml. In production, this points at the operator's own node.
CELLORA_CKB_RPC_URL=http://localhost:8114

# Poll cadence in milliseconds. The indexer sleeps this long when it catches up
# to the tip before asking the node for the next block.
CELLORA_POLL_INTERVAL_MS=2000

# Block number to start indexing from on a fresh database. Set to 0 for a full
# index of the chain. Ignored once a checkpoint row exists.
CELLORA_INDEXER_START_BLOCK=0

# Log level. Accepts any tracing-subscriber EnvFilter string.
# Examples: "info", "debug", "cellora_indexer=debug,sqlx=warn".
CELLORA_LOG_LEVEL=info

# Log output format: "json" (default, machine-readable) or "pretty" (human-readable).
CELLORA_LOG_FORMAT=pretty

# Socket address the API binary binds to.
CELLORA_API_BIND_ADDR=0.0.0.0:8080

# Default page size applied when a request does not specify `limit`.
CELLORA_API_DEFAULT_PAGE_SIZE=50

# Upper bound on `limit` accepted from clients.
CELLORA_API_MAX_PAGE_SIZE=500

# Per-request timeout enforced by the HTTP middleware stack (milliseconds).
CELLORA_API_REQUEST_TIMEOUT_MS=10000

# Refresh interval for the cached (indexer_tip, node_tip) snapshot.
CELLORA_API_TIP_CACHE_REFRESH_MS=1000

# In-process API-key verification cache.
CELLORA_API_AUTH_CACHE_TTL_SECONDS=60
CELLORA_API_AUTH_CACHE_CAPACITY=10000

# Redis used for per-key rate limiting (and, in later weeks, reorg pub/sub
# and webhook delivery).
CELLORA_REDIS_URL=redis://localhost:6379

# When true, requests are allowed if Redis is unreachable. Set to false
# to fail closed and return 503 on Redis outages.
CELLORA_API_RATE_LIMIT_FAIL_OPEN=true

# Per-tier REST rate limits. Burst is the bucket capacity; refill is
# tokens added per second.
CELLORA_API_RATE_LIMIT_FREE_REST_BURST=30
CELLORA_API_RATE_LIMIT_FREE_REST_REFILL_PER_SEC=1
CELLORA_API_RATE_LIMIT_STARTER_REST_BURST=300
CELLORA_API_RATE_LIMIT_STARTER_REST_REFILL_PER_SEC=20
CELLORA_API_RATE_LIMIT_PRO_REST_BURST=3000
CELLORA_API_RATE_LIMIT_PRO_REST_REFILL_PER_SEC=200

# Per-tier GraphQL rate limits — independent of REST.
CELLORA_API_RATE_LIMIT_FREE_GRAPHQL_BURST=10
CELLORA_API_RATE_LIMIT_FREE_GRAPHQL_REFILL_PER_SEC=0.5
CELLORA_API_RATE_LIMIT_STARTER_GRAPHQL_BURST=100
CELLORA_API_RATE_LIMIT_STARTER_GRAPHQL_REFILL_PER_SEC=10
CELLORA_API_RATE_LIMIT_PRO_GRAPHQL_BURST=1000
CELLORA_API_RATE_LIMIT_PRO_GRAPHQL_REFILL_PER_SEC=100

# Required for sqlx compile-time query checking during local development.
# Mirror CELLORA_DATABASE_URL.
DATABASE_URL=postgres://cellora:cellora@localhost:5432/cellora

# Set to true in CI so sqlx uses the committed .sqlx/ offline cache instead
# of connecting to a live database.
SQLX_OFFLINE=false
